              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">1</property>
              </packing>
            </child>
            <child>
              <object class="GtkToggleButton" id="tab_archived">
                <property name="label" translatable="yes" context="notification|tab_archived">Archived</property>
