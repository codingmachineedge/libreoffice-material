<?xml version="1.0" encoding="UTF-8"?>
<!-- This file is part of the LibreOffice project. -->
<!-- Non-dialog top-level (GtkGrid) so the Windows dialog-notification contract does not count it. -->
<!-- No GtkEntry/GtkComboBox text-query control here (INV-2): folder tabs + toggle/menu controls only. -->
<interface domain="sfx">
  <requires lib="gtk+" version="3.24"/>
  <object class="GtkTreeStore" id="notiflist_store">
    <columns>
      <!-- check -->
      <column type="gboolean"/>
      <!-- primary text -->
      <column type="gchararray"/>
      <!-- secondary text -->
      <column type="gchararray"/>
      <!-- id -->
      <column type="gchararray"/>
      <!-- check visible -->
      <column type="gboolean"/>
      <!-- check tristate -->
      <column type="gboolean"/>
    </columns>
  </object>
  <object class="GtkTreeStore" id="notifhistory_store">
    <columns>
      <!-- commit -->
      <column type="gchararray"/>
      <!-- affected -->
      <column type="gchararray"/>
      <!-- id -->
      <column type="gchararray"/>
    </columns>
  </object>
  <object class="GtkGrid" id="NotificationManager">
    <property name="visible">True</property>
    <property name="can-focus">False</property>
    <child>
      <object class="GtkBox" id="manager_root">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="orientation">vertical</property>
        <property name="spacing">8</property>
        <property name="width-request">820</property>
        <property name="height-request">620</property>
        <property name="hexpand">True</property>
        <property name="vexpand">True</property>
        <property name="margin-start">14</property>
        <property name="margin-end">14</property>
        <property name="margin-top">14</property>
        <property name="margin-bottom">14</property>
        <child>
          <object class="GtkBox" id="header">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="spacing">11</property>
            <child>
              <object class="GtkImage" id="header_icon">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="icon-name">dialog-information</property>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">0</property>
              </packing>
            </child>
            <child>
              <object class="GtkBox" id="header_titles">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="orientation">vertical</property>
                <property name="hexpand">True</property>
                <child>
                  <object class="GtkLabel" id="header_title">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="xalign">0</property>
                    <property name="label" translatable="yes" context="notification|manager_title">Notification manager</property>
                    <attributes>
                      <attribute name="weight" value="bold"/>
                      <attribute name="scale" value="1.2"/>
                    </attributes>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">0</property>
                  </packing>
                </child>
                <child>
                  <object class="GtkLabel" id="header_subtitle">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="xalign">0</property>
                    <property name="label" translatable="yes" context="notification|manager_subtitle">Bulk controls · recoverable delete · local Git audit trail</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="position">1</property>
                  </packing>
                </child>
              </object>
              <packing>
                <property name="expand">True</property>
                <property name="fill">True</property>
                <property name="position">1</property>
              </packing>
            </child>
            <child>
              <object class="GtkButton" id="close_button">
                <property name="visible">True</property>
                <property name="can-focus">True</property>
                <property name="receives-default">False</property>
                <property name="valign">start</property>
                <property name="tooltip-text" translatable="yes" context="notification|close_manager">Close notification manager</property>
                <child>
                  <object class="GtkImage" id="close_image">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="icon-name">window-close-symbolic</property>
                  </object>
                </child>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">2</property>
              </packing>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">0</property>
          </packing>
        </child>
        <child>
          <object class="GtkBox" id="folder_tabs">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="spacing">3</property>
            <child>
              <object class="GtkToggleButton" id="tab_inbox">
                <property name="label" translatable="yes" context="notification|tab_inbox">Inbox</property>
                <property name="visible">True</property>
                <property name="can-focus">True</property>
                <property name="receives-default">False</property>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">0</property>
              </packing>
            </child>
            <child>
              <object class="GtkToggleButton" id="tab_unread">
                <property name="label" translatable="yes" context="notification|tab_unread">Unread</property>
                <property name="visible">True</property>
