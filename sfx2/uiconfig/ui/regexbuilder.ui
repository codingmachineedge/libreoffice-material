                                <property name="AtkObject::accessible-role">static</property>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property><property name="fill">True</property><property name="position">1</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="reference_classes">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="label" translatable="yes" context="regexbuilder|reference_classes">Characters and classes
. matches any character except a newline unless s is enabled. \d matches a decimal digit, \s whitespace, and \w a Unicode word character. [abc] includes characters; [^abc] excludes them; [a-z] defines a range. Unicode properties use forms such as \p{Letter} and \p{Script=Greek}.</property>
                            <property name="wrap">True</property>
                            <property name="selectable">True</property>
                            <property name="xalign">0</property>
                            <child internal-child="accessible">
                              <object class="AtkObject" id="reference_classes-atkobject">
                                <property name="AtkObject::accessible-role">static</property>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property><property name="fill">True</property><property name="position">2</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="reference_groups">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="label" translatable="yes" context="regexbuilder|reference_groups">Groups and alternatives
(...) captures a group; (?:...) groups without capturing; a|b matches either branch. Refer to an earlier capture inside the pattern with \1. Use (?&lt;name>...) for a named capture where the consuming search surface supports named groups.</property>
                            <property name="wrap">True</property>
                            <property name="selectable">True</property>
                            <property name="xalign">0</property>
                            <child internal-child="accessible">
                              <object class="AtkObject" id="reference_groups-atkobject">
                                <property name="AtkObject::accessible-role">static</property>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property><property name="fill">True</property><property name="position">3</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="reference_lookaround">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="label" translatable="yes" context="regexbuilder|reference_lookaround">Lookaround
(?=...) requires a following match and (?!...) rejects it without consuming text. (?&lt;=...) and (?&lt;!...) do the same behind the current position. Keep lookbehind alternatives to bounded lengths accepted by ICU.</property>
                            <property name="wrap">True</property>
                            <property name="selectable">True</property>
                            <property name="xalign">0</property>
                            <child internal-child="accessible">
                              <object class="AtkObject" id="reference_lookaround-atkobject">
                                <property name="AtkObject::accessible-role">static</property>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property><property name="fill">True</property><property name="position">4</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="reference_quantifiers">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="label" translatable="yes" context="regexbuilder|reference_quantifiers">Quantifiers
* repeats zero or more times, + one or more, and ? zero or one. {n}, {n,}, and {n,m} set explicit bounds. Add ? for lazy matching or + for possessive matching, for example *? or *+.</property>
                            <property name="wrap">True</property>
                            <property name="selectable">True</property>
                            <property name="xalign">0</property>
                            <child internal-child="accessible">
                              <object class="AtkObject" id="reference_quantifiers-atkobject">
                                <property name="AtkObject::accessible-role">static</property>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property><property name="fill">True</property><property name="position">5</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="reference_escaping">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="label" translatable="yes" context="regexbuilder|reference_escaping">Escaping
Prefix a metacharacter with \ to search for it literally, such as \. or \[. Enclose a longer literal span in \Q and \E. Newline, tab, and a Unicode code point can be written as \n, \t, and \x{1F600}.</property>
                            <property name="wrap">True</property>
                            <property name="selectable">True</property>
                            <property name="xalign">0</property>
                            <child internal-child="accessible">
                              <object class="AtkObject" id="reference_escaping-atkobject">
                                <property name="AtkObject::accessible-role">static</property>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property><property name="fill">True</property><property name="position">6</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="reference_flags">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="label" translatable="yes" context="regexbuilder|reference_flags">Flags
i performs Unicode-aware case-insensitive matching. g returns all matches up to the safety limit; turn it off to stop after the first match. m makes ^ and $ recognize line boundaries. s lets . include newline characters. Literal mode supports i and g; m and s apply only to regular expressions.</property>
                            <property name="wrap">True</property>
                            <property name="selectable">True</property>
                            <property name="xalign">0</property>
                            <child internal-child="accessible">
                              <object class="AtkObject" id="reference_flags-atkobject">
                                <property name="AtkObject::accessible-role">static</property>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property><property name="fill">True</property><property name="position">7</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="reference_replacement">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="label" translatable="yes" context="regexbuilder|reference_replacement">Replacement backreferences
In search surfaces that provide replacement, $1 inserts the first captured group, $2 the second, and so on. Use a backslash to escape a literal dollar sign according to that surface's replacement rules. Search-only fields ignore replacement syntax.</property>
                            <property name="wrap">True</property>
                            <property name="selectable">True</property>
                            <property name="xalign">0</property>
                            <child internal-child="accessible">
                              <object class="AtkObject" id="reference_replacement-atkobject">
                                <property name="AtkObject::accessible-role">static</property>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property><property name="fill">True</property><property name="position">8</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel" id="reference_icu">
                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="label" translatable="yes" context="regexbuilder|reference_icu">ICU and LibreOffice notes
Applied searches use LibreOffice SearchOptions2 and TextSearch with ICU Unicode semantics, not the C++ standard-library engine. The separate live Test preview waits 200 ms after typing and then accepts at most 1,024 pattern code units, searches the first 16,384 UTF-16 code units, reports 256 matches, and limits ICU to 2,000 processing steps, 1 MiB of backtracking stack, and a 100 ms wall-clock callback deadline. It also expands LibreOffice's legacy \&lt; and \&gt; word-boundary forms. A clipped preview can differ at its boundary; Apply keeps the complete pattern and document search does not use these preview limits.</property>
                            <property name="wrap">True</property>
                            <property name="selectable">True</property>
                            <property name="xalign">0</property>
                            <child internal-child="accessible">
                              <object class="AtkObject" id="reference_icu-atkobject">
                                <property name="AtkObject::accessible-role">static</property>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property><property name="fill">True</property><property name="position">9</property></packing>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
              <packing><property name="position">2</property></packing>
            </child>
