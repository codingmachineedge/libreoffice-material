                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="label" translatable="yes" context="regexbuilder|example_date">ISO date
\b\d{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12]\d|3[01])\b
Finds YYYY-MM-DD-shaped dates and bounds month and day values.</property>
                            <property name="wrap">True</property>
