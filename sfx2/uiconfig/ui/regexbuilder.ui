                            <property name="visible">True</property>
                            <property name="can-focus">False</property>
                            <property name="label" translatable="yes" context="regexbuilder|example_email">Email-like address
\b[\w.%+-]+@[\w.-]+\.[A-Za-z]{2,}\b
Finds common email-style addresses. It is intentionally practical rather than a complete address validator.</property>
