<?xml version="1.0" encoding="UTF-8"?>

<!--
  LibreOffice Material Design 3 widget definition.

  This native theme deliberately uses VCL draw commands instead of a
  platform CSS layer. It therefore works with the same C++ renderer on every
  backend that enables file-defined widgets. The palette is the Material 3
  baseline purple scheme; component geometry uses rounded, tonal surfaces.
-->
