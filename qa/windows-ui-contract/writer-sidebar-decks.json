          "marker": "if (comphelper::LibreOfficeKit::isActive())",
          "note": "The LOK early-return branch (hide global tree + return before the mode toggle) is deliberately out of scope; it is not one of the pinned mode branches."
        },
        "branches": [
          {
            "name": "global-mode",
            "anchor": "if (!IsGlobalMode() && bGlobalDoc)",
            "shown": ["m_xGlobalBox", "m_xGlobalToolBox"],
