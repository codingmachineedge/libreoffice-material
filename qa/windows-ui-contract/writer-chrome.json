{
  "schema_version": 1,
  "contract": "material-writer-chrome-composition",
  "platform": "windows",
  "definition_file": "vcl/uiconfig/theme_definitions/material/definition.xml",
  "theme_flag": "VCL_FILE_WIDGET_THEME",
  "status": "source-declared",
  "runtime_verified": false,
  "design_reference": "docs/design/10-writer-calc.md (10.1 shared chrome, 10.2 Writer)",
  "note": "Pins the Writer classic-chrome composition (command identity+order, separator placement, per-button visibility) of the data-driven uiconfig XML, and grounds the Material treatment in the same shared native toolbar part contract in definition.xml that WIN-CA-001 pins (the toolbar band/separator/nine-state Button at @corner-toolbar is app-agnostic VCL, not Calc-specific). Scope is classic chrome only: the ribbon/notebookbar restyle is prototype-only (not yet in native source) per design 10.1, so it has no source to pin and is out of this contract. Composition is source-declared only; overflow/adaptive collapse and density selection remain build-dependent and are carved out as spec-only below. runtime_verified is false throughout: no native build, toolbar pixels, or runtime interaction are claimed.",
  "chrome_parts": {
    "control": "toolbar",
    "band": {
      "part": "DrawBackgroundHorz",
      "element": "rect",
      "tokens": {
        "stroke": "@surface-container",
        "fill": "@surface-container",
        "stroke-width": "@stroke-none"
      }
    },
    "entire": {
      "part": "Entire",
      "element": "rect",
      "tokens": {
        "stroke": "@surface-container",
        "fill": "@surface-container",
        "stroke-width": "@stroke-none"
      }
    },
    "separator": {
      "part": "SeparatorVert",
      "element": "line",
      "tokens": {
        "stroke": "@outline-variant",
        "stroke-width": "@stroke-thin"
      }
    },
    "button": {
      "part": "Button",
      "states": [
        {
          "role": "enabled",
          "attrs": {
            "enabled": "true"
          },
          "element": "rect",
          "tokens": {
            "stroke": "@surface-container",
            "fill": "@surface-container",
            "stroke-width": "@stroke-none",
            "radius": "@corner-toolbar"
          }
        },
        {
          "role": "rollover",
          "attrs": {
            "enabled": "true",
            "rollover": "true"
          },
          "element": "rect",
          "tokens": {
            "stroke": "@primary-container",
            "fill": "@primary-container",
            "stroke-width": "@stroke-none",
            "radius": "@corner-toolbar"
          }
        },
        {
          "role": "pressed",
          "attrs": {
            "enabled": "true",
            "pressed": "true"
          },
          "element": "rect",
          "tokens": {
            "stroke": "@primary-hover",
            "fill": "@primary-hover",
            "stroke-width": "@stroke-none",
            "radius": "@corner-toolbar"
          }
        },
        {
          "role": "checked",
          "attrs": {
            "enabled": "true",
            "button-value": "true"
          },
          "element": "rect",
          "tokens": {
            "stroke": "@primary",
            "fill": "@primary-container",
            "stroke-width": "@stroke-thin",
            "radius": "@corner-toolbar"
          }
        },
        {
          "role": "rollover-checked",
          "attrs": {
            "enabled": "true",
            "rollover": "true",
            "button-value": "true"
          },
          "element": "rect",
          "tokens": {
            "stroke": "@primary",
            "fill": "@primary-hover",
            "stroke-width": "@stroke-thin",
            "radius": "@corner-toolbar"
          }
        },
        {
          "role": "pressed-checked",
          "attrs": {
            "enabled": "true",
            "pressed": "true",
            "button-value": "true"
          },
          "element": "rect",
          "tokens": {
            "stroke": "@primary",
            "fill": "@primary-pressed",
            "stroke-width": "@stroke-thin",
            "radius": "@corner-toolbar"
          }
        },
        {
          "role": "focused",
          "attrs": {
            "enabled": "true",
            "focused": "true"
          },
          "element": "rect",
          "tokens": {
            "stroke": "@primary",
            "fill": "@surface-container",
            "stroke-width": "@stroke-standard",
            "radius": "@corner-toolbar"
          }
        },
        {
          "role": "disabled",
          "attrs": {
            "enabled": "false"
          },
          "element": "rect",
          "tokens": {
            "stroke": "@disabled-container",
            "fill": "@disabled-container",
            "stroke-width": "@stroke-none",
            "radius": "@corner-toolbar"
          }
        },
        {
          "role": "disabled-checked",
          "attrs": {
            "enabled": "false",
            "button-value": "true"
          },
          "element": "rect",
          "tokens": {
            "stroke": "@outline",
            "fill": "@disabled-container",
            "stroke-width": "@stroke-thin",
            "radius": "@corner-toolbar"
          }
        }
      ]
    },
    "metrics": [
