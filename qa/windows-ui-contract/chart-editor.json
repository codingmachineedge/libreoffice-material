            "enabled": "false",
            "button-value": "true"
          },
          "element": "rect",
          "tokens": {
            "stroke": "@outline",
            "fill": "@disabled-container",
            "stroke-width": "@stroke-thin",
            "radius": "@corner-toolbar"
          }
        }
      ]
    },
    "metrics": [
