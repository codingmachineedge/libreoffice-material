          "element": "rect",
          "tokens": {
            "stroke": "@primary",
            "fill": "@primary-container",
            "stroke-width": "@stroke-thin",
            "radius": "@corner-toolbar"
          }
        },
        {
          "role": "rollover-checked",
          "attrs": {
            "enabled": "true",
            "rollover": "true",
            "button-value": "true"
          },
          "element": "rect",
          "tokens": {
            "stroke": "@primary",
            "fill": "@primary-hover",
            "stroke-width": "@stroke-thin",
            "radius": "@corner-toolbar"
          }
        },
        {
          "role": "pressed-checked",
          "attrs": {
            "enabled": "true",
            "pressed": "true",
            "button-value": "true"
          },
          "element": "rect",
          "tokens": {
            "stroke": "@primary",
            "fill": "@primary-pressed",
            "stroke-width": "@stroke-thin",
            "radius": "@corner-toolbar"
          }
        },
        {
          "role": "focused",
          "attrs": {
            "enabled": "true",
            "focused": "true"
          },
          "element": "rect",
          "tokens": {
            "stroke": "@primary",
            "fill": "@surface-container",
            "stroke-width": "@stroke-standard",
            "radius": "@corner-toolbar"
          }
        },
        {
          "role": "disabled",
          "attrs": {
            "enabled": "false"
          },
          "element": "rect",
          "tokens": {
            "stroke": "@disabled-container",
            "fill": "@disabled-container",
            "stroke-width": "@stroke-none",
            "radius": "@corner-toolbar"
          }
        },
        {
