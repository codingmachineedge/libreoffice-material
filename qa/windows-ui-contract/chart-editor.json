            "stroke-width": "@stroke-none",
            "radius": "@corner-toolbar"
          }
        },
        {
          "role": "pressed",
          "attrs": {
            "enabled": "true",
            "pressed": "true"
          },
          "element": "rect",
          "tokens": {
            "stroke": "@primary-hover",
