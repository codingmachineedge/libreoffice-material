  "carveouts": {
    "chart_canvas": {
      "status": "specified",
      "note": "The chart drawing surface is custom-drawn by chart2 drawinglayer with no .ui and no themeable definition.xml part; its Material re-theme is build-bound (M is a roadmap target only, no Material-specific chart source exists) and never promoted by this composition pin."
    },
    "live_preview": {
      "status": "specified",
      "note": "Double-click-to-edit OLE activation and the live chart preview are runtime-only; not observable by a static contract."
    },
    "data_table_grid": {
