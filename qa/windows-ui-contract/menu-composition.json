{
  "description": "WIN-NAV-001 menubar + drop-menu composition contract. Cross-validates the Material menu part/state/metric declarations in vcl/uiconfig/theme_definitions/material/definition.xml against the real cross-platform menu layout that consumes them: the settings -> NWF -> Menu::ImplCalcSize channel that carries the design-05 1.1/1.5 anatomy (band/row heights, drop-menu minimum width, 6px inner border, 14px accelerator-column gap) plus the milestone-10 dimmed disabled-submenu-arrow plumbing. Source evidence only; no build, menu pixels, or runtime interaction are claimed.",
  "definition_xml": "vcl/uiconfig/theme_definitions/material/definition.xml",
  "indicator_metric": {
    "name": "size-menu-indicator",
    "value": 18
  },
  "menu_settings": {
    "menuBarHeight": 38,
    "menuItemHeight": 40,
    "menuPopupMinWidth": 248,
    "menuAccelColumnGap": 14,
    "menuInnerBorder": 6
  },
  "menubar_part_states": {
    "Entire": [
      { "state": {}, "fill": "@surface-container", "stroke_width": "@stroke-none" }
    ],
    "MenuItem": [
      { "state": {}, "fill": "@surface-container", "radius": "@corner-container" },
      { "state": { "rollover": "true" }, "fill": "@primary-container" },
      { "state": { "selected": "true" }, "fill": "@primary-hover" }
    ]
  },
  "menupopup_part_states": {
    "Entire": [
      { "state": {}, "fill": "@surface", "stroke": "@outline-variant", "stroke_width": "@stroke-thin", "radius": "@corner-container" }
    ],
    "MenuItem": [
      { "state": {}, "fill": "@surface", "radius": "@corner-small" },
      { "state": { "rollover": "true" }, "fill": "@primary-container" },
      { "state": { "selected": "true" }, "fill": "@primary-hover" }
    ]
  },
  "menupopup_indicators": {
    "MenuItemCheckMark": {
      "size_metric": "@size-menu-indicator",
      "enabled_state": { "enabled": "true", "pressed": "true" },
      "enabled_stroke": "@primary",
      "disabled_state": { "enabled": "false", "pressed": "true" },
      "disabled_stroke": "@outline",
      "element": "line"
    },
    "MenuItemRadioMark": {
      "size_metric": "@size-menu-indicator",
      "enabled_state": { "enabled": "true", "pressed": "true" },
      "enabled_stroke": "@primary",
      "disabled_state": { "enabled": "false", "pressed": "true" },
      "disabled_stroke": "@outline",
      "element": "rect"
    },
    "SubmenuArrow": {
      "size_metric": "@size-menu-indicator",
      "enabled_state": {},
      "enabled_stroke": "@on-surface-variant",
      "disabled_state": { "enabled": "false" },
      "disabled_stroke": "@outline",
      "element": "line"
    }
  },
  "menupopup_separator": {
    "part": "Separator",
    "stroke": "@outline-variant",
    "stroke_width": "@stroke-thin"
  },
  "nwf_fields": [
    "mnMenuBarHeight",
    "mnMenuItemHeight",
    "mnMenuPopupMinWidth",
    "mnMenuAccelColumnGap"
  ],
  "code_markers": [
    {
      "id": "nwf-field-barheight",
      "file": "vcl/inc/svdata.hxx",
      "pattern": "int\\s+mnMenuBarHeight\\s*=\\s*0;",
      "why": "menubar band height NWF channel is declared"
    },
    {
      "id": "nwf-field-itemheight",
      "file": "vcl/inc/svdata.hxx",
      "pattern": "int\\s+mnMenuItemHeight\\s*=\\s*0;",
      "why": "command-row height NWF channel is declared"
    },
    {
      "id": "nwf-field-minwidth",
      "file": "vcl/inc/svdata.hxx",
      "pattern": "int\\s+mnMenuPopupMinWidth\\s*=\\s*0;",
      "why": "drop-menu minimum width NWF channel is declared"
    },
    {
      "id": "nwf-field-accelgap",
      "file": "vcl/inc/svdata.hxx",
      "pattern": "int\\s+mnMenuAccelColumnGap\\s*=\\s*0;",
      "why": "accelerator-column gap NWF channel is declared"
    },
    {
      "id": "reader-barheight",
      "file": "vcl/source/gdi/WidgetDefinitionReader.cxx",
      "pattern": "\"menuBarHeight\"[^\\n]*msMenuBarHeight",
      "why": "menuBarHeight setting is mapped into the widget definition"
    },
    {
      "id": "reader-itemheight",
      "file": "vcl/source/gdi/WidgetDefinitionReader.cxx",
      "pattern": "\"menuItemHeight\"[^\\n]*msMenuItemHeight",
      "why": "menuItemHeight setting is mapped into the widget definition"
    },
    {
      "id": "reader-minwidth",
      "file": "vcl/source/gdi/WidgetDefinitionReader.cxx",
      "pattern": "\"menuPopupMinWidth\"[^\\n]*msMenuPopupMinWidth",
      "why": "menuPopupMinWidth setting is mapped into the widget definition"
    },
    {
      "id": "reader-accelgap",
      "file": "vcl/source/gdi/WidgetDefinitionReader.cxx",
      "pattern": "\"menuAccelColumnGap\"[^\\n]*msMenuAccelColumnGap",
      "why": "menuAccelColumnGap setting is mapped into the widget definition"
    },
    {
      "id": "reader-innerborder",
      "file": "vcl/source/gdi/WidgetDefinitionReader.cxx",
      "pattern": "\"menuInnerBorder\"[^\\n]*msMenuInnerBorder",
      "why": "menuInnerBorder setting is mapped into the widget definition"
    },
    {
      "id": "populate-barheight",
      "file": "vcl/source/gdi/FileDefinitionWidgetDraw.cxx",
      "pattern": "mnMenuBarHeight\\s*=\\s*getSettingValueInteger\\(\\s*pSettings->msMenuBarHeight",
      "why": "band height flows from the definition into NWF only when Material is live"
    },
    {
      "id": "populate-itemheight",
      "file": "vcl/source/gdi/FileDefinitionWidgetDraw.cxx",
      "pattern": "mnMenuItemHeight\\s*=\\s*getSettingValueInteger\\(\\s*pSettings->msMenuItemHeight",
      "why": "command-row height flows from the definition into NWF only when Material is live"
    },
    {
      "id": "populate-minwidth",
      "file": "vcl/source/gdi/FileDefinitionWidgetDraw.cxx",
      "pattern": "mnMenuPopupMinWidth\\s*=\\s*getSettingValueInteger\\(\\s*pSettings->msMenuPopupMinWidth",
      "why": "drop-menu minimum width flows from the definition into NWF only when Material is live"
    },
    {
      "id": "populate-accelgap",
      "file": "vcl/source/gdi/FileDefinitionWidgetDraw.cxx",
      "pattern": "mnMenuAccelColumnGap\\s*=\\s*getSettingValueInteger\\(\\s*pSettings->msMenuAccelColumnGap",
      "why": "accelerator-column gap flows from the definition into NWF only when Material is live"
    },
    {
      "id": "populate-innerborder",
      "file": "vcl/source/gdi/FileDefinitionWidgetDraw.cxx",
      "pattern": "mnMenuFormatBorderX\\s*=\\s*getSettingValueInteger\\(\\s*pSettings->msMenuInnerBorder",
      "why": "6px inner border flows from the definition into the existing popup-border NWF field"
    },
    {
      "id": "populate-baseline-capture",
      "file": "vcl/source/gdi/FileDefinitionWidgetDraw.cxx",
      "pattern": "aBaseline\\.mnMenuBarHeight\\s*=\\s*rNWFData\\.mnMenuBarHeight",
      "why": "the platform baseline is captured so the guard is reversible on theme teardown"
    },
    {
      "id": "populate-baseline-restore",
      "file": "vcl/source/gdi/FileDefinitionWidgetDraw.cxx",
      "pattern": "rNWFData\\.mnMenuBarHeight\\s*=\\s*aBaseline\\.mnMenuBarHeight",
      "why": "the platform baseline is restored so non-Material rendering is never touched"
    },
    {
      "id": "layout-nwf-reference",
      "file": "vcl/source/window/menu.cxx",
      "pattern": "const ImplSVNWFData&\\s*rMenuNWFData\\s*=\\s*ImplGetSVData\\(\\)->maNWFData;",
      "why": "ImplCalcSize reads the Material menu metrics from the NWF channel"
    },
    {
      "id": "layout-itemheight",
      "file": "vcl/source/window/menu.cxx",
      "pattern": "nMinMenuItemHeight\\s*=\\s*rMenuNWFData\\.mnMenuItemHeight",
      "why": "command rows honour the Material minimum row height"
    },
    {
      "id": "layout-accelgap",
      "file": "vcl/source/window/menu.cxx",
      "pattern": "rMenuNWFData\\.mnMenuAccelColumnGap\\s*>\\s*0[^;]*rMenuNWFData\\.mnMenuAccelColumnGap",
      "why": "the accelerator column reserves the Material gap width"
    },
    {
      "id": "layout-minwidth",
      "file": "vcl/source/window/menu.cxx",
      "pattern": "aSz\\.setWidth\\(\\s*rMenuNWFData\\.mnMenuPopupMinWidth\\s*\\);",
      "why": "the drop menu never opens narrower than the Material minimum width"
    },
    {
      "id": "layout-barheight",
      "file": "vcl/source/window/menu.cxx",
      "pattern": "aSz\\.setHeight\\(\\s*rMenuNWFData\\.mnMenuBarHeight\\s*\\);",
      "why": "the menubar band honours the Material minimum band height"
    },
    {
      "id": "layout-disabled-arrow",
      "file": "vcl/source/window/menu.cxx",
      "pattern": "IsNativeControlSupported\\(ControlType::MenuPopup,\\s*ControlPart::SubmenuArrow\\)(?:(?!DrawNativeControl).)*?pData->bEnabled\\s*&&\\s*m_pWindow->IsEnabled\\(\\)(?:(?!DrawNativeControl).)*?nState\\s*\\|=\\s*ControlState::ENABLED(?:(?!DrawNativeControl).)*?DrawNativeControl\\(ControlType::MenuPopup,\\s*ControlPart::SubmenuArrow",
      "why": "a disabled submenu parent draws its arrow through the enabled=false @outline definition state"
    },
    {
      "id": "accel-source",
      "file": "framework/source/uielement/menubarmanager.cxx",
      "pattern": "SetAcceleratorKeys\\(\\s*pMenu\\s*\\);",
      "why": "the framework populates the accelerator keys the native accelerator column then lays out"
    },
    {
      "id": "padding-consumer",
      "file": "vcl/source/window/menufloatingwindow.cxx",
      "pattern": "maNWFData\\.mnMenuFormatBorderY",
      "why": "the floating drop-menu window honours the inner-border padding"
    }
  ],
  "context_menu": {
    "description": "WIN-NAV-002 context-menu delta on top of NAV-001 (docs/design/05-navigation.md section 2). New-behaviour markers fail closed on the Material keyboard-first-highlight policy and its reversible NWF guard, the single native keyboard-vs-pointer capture at ImplCallCommand, and its one-shot consumption in PopupMenu::ImplExecute. Presence markers pin the shared-VCL behaviours section 2 relies on so they cannot silently regress: on-screen edge-flip and RTL mirroring in FloatingWindow::ImplCalcPos, the StartPopupMode anchor feed, focus save/return around a top-level context execute, Esc dismissal, and the Writer-canvas / Calc-sheet-tab invocation hooks. Source evidence only; no build, menu pixels, or runtime interaction are claimed.",
    "definition_setting": {
      "name": "contextMenuKeyboardFirstHighlight",
      "value": "true"
    },
    "nwf_fields": ["mbContextMenuKeyboardFirstHighlight"],
    "appdata_fields": ["mbContextMenuByKeyboard"],
    "code_markers": [
      {
        "id": "ctx-nwf-policy-field",
        "file": "vcl/inc/svdata.hxx",
        "pattern": "bool\\s+mbContextMenuKeyboardFirstHighlight\\s*=\\s*false;",
        "why": "the Material keyboard-first-highlight policy is declared on the NWF channel (0/false = untouched platform behaviour)"
      },
      {
        "id": "ctx-appdata-flag",
        "file": "vcl/inc/svdata.hxx",
        "pattern": "bool\\s+mbContextMenuByKeyboard\\s*=\\s*false;",
        "why": "the transient keyboard-invocation flag is declared on the app-data channel"
      },
      {
        "id": "ctx-widgetdef-setting",
        "file": "vcl/inc/widgetdraw/WidgetDefinition.hxx",
        "pattern": "OString\\s+msContextMenuKeyboardFirstHighlight\\s*;",
        "why": "the WidgetDefinitionSettings string field that carries the contextMenuKeyboardFirstHighlight setting from the reader into the file-definition theme is declared"
      },
      {
        "id": "ctx-reader-map",
        "file": "vcl/source/gdi/WidgetDefinitionReader.cxx",
        "pattern": "\"contextMenuKeyboardFirstHighlight\"\\s*,\\s*&rWidgetDefinition\\.mpSettings->msContextMenuKeyboardFirstHighlight",
        "why": "the contextMenuKeyboardFirstHighlight setting is mapped into the widget definition"
      },
      {
        "id": "ctx-populate",
        "file": "vcl/source/gdi/FileDefinitionWidgetDraw.cxx",
        "pattern": "rNWFData\\.mbContextMenuKeyboardFirstHighlight\\s*=\\s*getSettingValueBool\\(\\s*pSettings->msContextMenuKeyboardFirstHighlight",
        "why": "the policy flows from the definition into NWF only while the Material theme is live"
      },
      {
        "id": "ctx-baseline-capture",
        "file": "vcl/source/gdi/FileDefinitionWidgetDraw.cxx",
        "pattern": "aBaseline\\.mbContextMenuKeyboardFirstHighlight\\s*=\\s*rNWFData\\.mbContextMenuKeyboardFirstHighlight",
        "why": "the platform baseline is captured so the policy guard is reversible on theme teardown"
      },
      {
        "id": "ctx-baseline-restore",
        "file": "vcl/source/gdi/FileDefinitionWidgetDraw.cxx",
        "pattern": "rNWFData\\.mbContextMenuKeyboardFirstHighlight\\s*=\\s*aBaseline\\.mbContextMenuKeyboardFirstHighlight",
        "why": "the platform baseline is restored so non-Material context menus are never touched"
      },
      {
        "id": "ctx-capture-keyboard",
        "file": "vcl/source/window/winproc.cxx",
        "pattern": "nEvt\\s*==\\s*CommandEventId::ContextMenu\\s*\\)\\s*ImplGetSVData\\(\\)->maAppData\\.mbContextMenuByKeyboard\\s*=\\s*!bMouse",
        "why": "the single native choke point records keyboard-vs-pointer invocation for every context menu"
      },
      {
        "id": "ctx-consume-highlight",
        "file": "vcl/source/window/menu.cxx",
        "pattern": "bContextKeyboardFirstHighlight\\s*=\\s*bRealExecute\\s*&&\\s*!pStartedFrom\\s*&&\\s*bContextMenuByKeyboard\\s*&&\\s*pSVData->maNWFData\\.mbContextMenuKeyboardFirstHighlight",
        "why": "pre-highlight is enabled only for a top-level keyboard-invoked context menu while the Material policy is live"
      },
      {
        "id": "ctx-consume-applied",
        "file": "vcl/source/window/menu.cxx",
        "pattern": "Run\\(pWin,\\s*bRealExecute,\\s*bPreSelectFirst\\s*\\|\\|\\s*bContextKeyboardFirstHighlight",
        "why": "the computed keyboard-first-highlight is folded into the ImplExecute -> Run pre-select path"
      },
      {
        "id": "ctx-placement-feed",
        "file": "vcl/source/window/menu.cxx",
        "pattern": "pWin->StartPopupMode\\(rRect,\\s*nPopupModeFlags\\)",
        "why": "the pointer-or-caret anchor rect feeds the FloatingWindow placement channel"
      },
      {
        "id": "ctx-edge-flip",
        "file": "vcl/source/window/floatwin.cxx",
        "pattern": "for\\s*\\(\\s*;\\s*nArrangeIndex\\s*<\\s*nArrangeAttempts;\\s*nArrangeIndex\\+\\+\\s*\\)",
        "why": "ImplCalcPos retries placement arrangements so a near-edge popup flips to stay on-screen"
      },
      {
        "id": "ctx-rtl-mirror",
        "file": "vcl/source/window/floatwin.cxx",
        "pattern": "if\\(\\s*bRTL\\s*\\)\\s*devRectRTL\\s*=\\s*pW->ImplOutputToUnmirroredAbsoluteScreenPixel\\(\\s*normRect\\s*\\)",
        "why": "the on-screen flip compares against unmirrored desktop coordinates so it mirrors in RTL"
      },
      {
        "id": "ctx-focus-save",
        "file": "vcl/source/window/menu.cxx",
        "pattern": "!pStartedFrom\\s*\\)(?:(?!SaveFocus).)*?xFocusId\\s*=\\s*Window::SaveFocus\\(\\)",
        "why": "a top-level context execute saves the invoking control's focus"
      },
      {
        "id": "ctx-focus-return",
        "file": "vcl/source/window/menufloatingwindow.cxx",
        "pattern": "xFocusId\\(xSaveFocusId\\)(?:(?!EndSaveFocus).)*?Window::EndSaveFocus\\(xFocusId\\)",
        "why": "closing the popup returns focus to the saved invoking control"
      },
      {
        "id": "ctx-esc-dismiss",
        "file": "vcl/source/window/menufloatingwindow.cxx",
        "pattern": "case KEY_ESCAPE:(?:(?!case KEY_LEFT).)*?!pMenu->pStartedFrom\\s*\\)\\s*\\{\\s*StopExecute\\(\\);\\s*KillActivePopup\\(\\)",
        "why": "Esc dismisses a top-level context menu, driving the focus-return path"
      },
      {
        "id": "ctx-writer-hook",
        "file": "sw/source/uibase/docvw/edtwin.cxx",
        "pattern": "!rCEvt\\.IsMouseEvent\\(\\)\\s*\\)\\s*aDocPos\\s*=\\s*rSh\\.GetCharRect\\(\\)\\.Center\\(\\)",
        "why": "the Writer-canvas nav-context hook opens a keyboard-invoked menu at the caret, not the pointer"
      },
      {
        "id": "ctx-calc-hook",
        "file": "sc/source/ui/view/tabcont.cxx",
        "pattern": "CommandEventId::ContextMenu(?:(?!ExecutePopup).)*?ExecutePopup\\(\\s*u\"sheettab\"_ustr\\s*\\)",
        "why": "the Calc sheet-tab-strip nav-context hook opens its context menu"
      }
    ]
  }
}
