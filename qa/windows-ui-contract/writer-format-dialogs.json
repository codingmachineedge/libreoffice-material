            "enabled": "true",
            "focused": "true"
          },
          "tokens": {
            "stroke": "@primary",
            "fill": "@surface-container",
            "stroke-width": "@stroke-standard",
            "radius": "@corner-pill"
          }
        },
        {
          "role": "active-hover",
