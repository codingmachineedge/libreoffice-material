            "radius": "@corner-pill"
          }
        },
        {
          "role": "active-focus",
          "attrs": {
            "enabled": "true",
            "selected": "true",
            "focused": "true"
          },
          "tokens": {
            "stroke": "@primary",
            "fill": "@primary-container",
            "stroke-width": "@stroke-standard",
            "radius": "@corner-pill"
          }
        },
