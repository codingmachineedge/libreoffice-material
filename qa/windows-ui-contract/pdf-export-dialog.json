    "primary": {
      "id": "ok",
      "label": "E_xport",
      "has_default": true,
      "note": "Export is the Enter default because it is non-destructive; no destructive-confirmation pattern applies."
    }
  },
  "tab_sequence": ["general", "initialview", "userinterface", "links", "security", "digitalsignatures"],
  "cur_page": "general",
  "tab_pages": [
