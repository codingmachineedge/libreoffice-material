        { "id": "cancel", "class": "GtkButton", "absent_or_false": ["has-default"] },
        { "id": "filelist", "class": "GtkTreeView" },
        { "id": "savedir", "class": "GtkEntry" },
        { "id": "change", "class": "GtkButton" }
