              "weld_marker": "weld_label(\"datelabel\")"
            },
            {
              "id": "timelabel",
              "weld_marker": "weld_label(\"timelabel\")"
            },
            {
              "id": "replybutton",
              "weld_marker": "weld_button(\"replybutton\")"
            },
            {
              "id": "resolvebutton",
              "weld_marker": "weld_check_button(\"resolvebutton\")"
            },
