{
  "schema_version": 1,
  "contract": "material-writer-review-composition",
  "platform": "windows",
  "definition_file": "vcl/uiconfig/theme_definitions/material/definition.xml",
  "theme_flag": "VCL_FILE_WIDGET_THEME",
  "status": "source-declared",
  "runtime_verified": false,
  "design_reference": "docs/design/10-writer-calc.md (Review, tracked changes and comments composition) -- cited by section title, not number (chapter-10 review subsection authored concurrently).",
  "note": "WIN-WR-005. Composition-pinning contract over Writer's three real, already-registered review/collaboration surfaces: (1) the Track Changes toolbar (changes.xml, registered as private:resource/toolbar/changes / UIName 'Track Changes' in WriterWindowState.xcu) whose ordered command sequence spans review+comments+tracked-changes+collaboration; (2) the Comments sidebar deck (Sidebar.xcu CommentsDeck/CommentsPanel -> SwPanelFactory /CommentsPanel -> CommentsPanel.cxx over commentspanel.ui + the per-thread Comment widget over commentwidget.ui); (3) the Manage Changes sidebar deck (Sidebar.xcu SwManageChangesDeck/SwManageChangesPanel -> SwPanelFactory /ManageChangesPanel -> redlndlg.cxx SwRedlineAcceptPanel, which mounts the SHARED svx accept/reject control SvxAcceptChgCtr rather than a Writer-private widget). The contract pins toolbar command identity+order+separator placement, the Id/DeckId/ImplementationURL registry chain, the factory dispatch, and every weld-id binding cross-checked against its .ui, so a renamed/dropped id, reordered command, or broken resource-URL dispatch fails closed. It reuses the already-validated generic native toolbar Button nine-state part (WIN-CA-001) -- no new tokens are invented. Search is excluded (owned by regex-search-integrations.json / search-field-coverage.json). The Manage Changes deck asserts only that Writer MOUNTS the shared svx control, not the control's own internal layout (which belongs at the svx level, shared with any future Calc tracked-changes row). runtime_verified is false throughout: no native build, toolbar/deck pixels, or runtime interaction are claimed; today these surfaces render with zero Material differentiation (no VCL_FILE_WIDGET_THEME guard in the panel .cxx).",
  "toolbar": {
    "id": "changes",
    "file": "sw/uiconfig/swriter/toolbar/changes.xml",
    "registration": {
      "source": "officecfg/registry/data/org/openoffice/Office/UI/WriterWindowState.xcu",
      "markers": [
        "private:resource/toolbar/changes",
        "<value xml:lang=\"en-US\">Track Changes</value>"
      ]
    },
    "design_core": [
      ".uno:ShowTrackedChanges",
      ".uno:TrackChanges",
      ".uno:AcceptTrackedChange",
      ".uno:RejectTrackedChange",
      ".uno:AcceptAllTrackedChanges",
      ".uno:RejectAllTrackedChanges",
      ".uno:InsertAnnotation",
      ".uno:CompareDocuments",
      ".uno:MergeDocuments"
    ],
    "sequence": [
      {
        "command": ".uno:ShowTrackedChanges",
        "visible": true
      },
      {
        "command": ".uno:TrackChanges",
        "visible": true
      },
      {
        "separator": true
      },
      {
        "command": ".uno:PreviousTrackedChange",
        "visible": true
      },
      {
        "command": ".uno:NextTrackedChange",
        "visible": true
      },
      {
        "command": ".uno:AcceptTrackedChange",
        "visible": true
      },
      {
        "command": ".uno:RejectTrackedChange",
        "visible": true
      },
      {
        "command": ".uno:AcceptAllTrackedChanges",
        "visible": true
      },
      {
        "command": ".uno:RejectAllTrackedChanges",
        "visible": true
      },
      {
        "command": ".uno:AcceptTrackedChangeToNext",
        "visible": true
      },
      {
        "command": ".uno:RejectTrackedChangeToNext",
        "visible": true
      },
      {
        "command": ".uno:AcceptTrackedChanges",
        "visible": true
      },
      {
        "separator": true
      },
      {
        "command": ".uno:InsertAnnotation",
        "visible": true
      },
      {
        "command": ".uno:CommentChangeTracking",
        "visible": true
      },
      {
        "separator": true
      },
      {
        "command": ".uno:ProtectTraceChangeMode",
        "visible": true
      },
      {
        "command": ".uno:CompareDocuments",
        "visible": true
      },
      {
        "command": ".uno:MergeDocuments",
        "visible": true
      }
    ]
  },
  "decks": [
    {
      "surface_id": "writer.review.comments",
      "title": "Comments sidebar deck (CommentsPanel + per-thread Comment widget)",
      "status": "source-declared",
      "runtime_verified": false,
      "registration": {
        "source": "officecfg/registry/data/org/openoffice/Office/UI/Sidebar.xcu",
        "markers": [
          "<node oor:name=\"CommentsDeck\" oor:op=\"replace\">",
          "<node oor:name=\"CommentsPanel\" oor:op=\"replace\">",
          "private:resource/toolpanel/SwPanelFactory/CommentsPanel"
        ]
      },
      "factory": {
        "source": "sw/source/uibase/sidebar/SwPanelFactory.cxx",
        "resource_suffix": "/CommentsPanel",
        "create_call": "sw::sidebar::CommentsPanel::Create"
      },
      "panels": [
