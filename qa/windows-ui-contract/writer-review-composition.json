      ]
    },
    {
      "surface_id": "writer.review.manage-changes",
      "title": "Manage Changes sidebar deck (SwRedlineAcceptPanel mounting shared svx SvxAcceptChgCtr)",
      "status": "source-declared",
      "runtime_verified": false,
      "registration": {
        "source": "officecfg/registry/data/org/openoffice/Office/UI/Sidebar.xcu",
        "markers": [
          "<node oor:name=\"SwManageChangesDeck\" oor:op=\"replace\">",
          "<node oor:name=\"SwManageChangesPanel\" oor:op=\"replace\">",
          "private:resource/toolpanel/SwPanelFactory/ManageChangesPanel"
        ]
      },
      "factory": {
        "source": "sw/source/uibase/sidebar/SwPanelFactory.cxx",
        "resource_suffix": "/ManageChangesPanel",
        "create_call": "std::make_unique<SwRedlineAcceptPanel>(pParent)"
      },
      "panels": [
        {
          "name": "manage-changes-panel",
          "source": "sw/source/uibase/misc/redlndlg.cxx",
          "ui_file": "sw/uiconfig/swriter/ui/managechangessidebar.ui",
          "ui_load": "modules/swriter/ui/managechangessidebar.ui",
          "widgets": [
            {
              "id": "content_area",
              "weld_marker": "weld_container(u\"content_area\"_ustr)"
            }
          ]
        }
      ],
      "shared_mount": {
        "source": "sw/source/uibase/misc/redlndlg.cxx",
        "note": "Writer's Manage Changes deck constructs SwRedlineAcceptDlg which mounts the SHARED svx accept/reject control SvxAcceptChgCtr; this pins that Writer MOUNTS the shared control, not the control's own internal layout (that belongs at the svx level, shared with any future Calc row).",
        "markers": [
          "mpImplDlg.reset(new SwRedlineAcceptDlg(nullptr, m_xBuilder.get(), mxContentArea.get()))",
          "SwRedlineAcceptDlg::SwRedlineAcceptDlg(",
          "new SvxAcceptChgCtr(pContentArea)"
        ]
      }
    }
  ]
}
